# ===== Palworld Server Configuration =====
#
# This file is loaded by docker-compose and controls server behavior.
# It is intended to be committed (no secrets here); put passwords/etc in .env.secrets.
#
# For detailed per-setting documentation, see:
#   - Server settings: https://palworld-server-docker.loef.dev/getting-started/configuration/server-settings
#   - Game settings:   https://palworld-server-docker.loef.dev/getting-started/configuration/game-settings
#

# --- Runtime / Docker settings --------------------------------------------------
# Basic container-related configuration.

TZ=UTC                         # Timezone used by the container (e.g., UTC, Europe/Berlin)
PLAYERS=10                     # Max concurrent players (server-level cap)
PORT=8211                      # UDP port for the Palworld game server
PUID=1000                      # UID used by container to create files (use 1000 for normal user)
PGID=1000                      # GID used by container to create files
MULTITHREADING=true            # enable multithreaded server
COMMUNITY=true                 # allow community/public server listing

# --- Process manager / auto-update / backup -----------------------------------
# The following values are used by the docker wrapper, not the game itself.

UPDATE_ON_BOOT=true                         # auto-update the container on startup
RCON_ENABLED=false                          # enable remote console (RCON)
RCON_PORT=25575                             # Port for RCON (TCP)
QUERY_PORT=27015                            # Port used for Steam server queries (UDP)
BACKUP_ENABLED=true                         # enable automatic save backups
DELETE_OLD_BACKUPS=true                     # delete backups older than OLD_BACKUP_DAYS
OLD_BACKUP_DAYS=30                          # Number of days before old backups are removed
BACKUP_CRON_EXPRESSION=0 0 * * *            # Cron schedule for backups (standard cron syntax)
AUTO_UPDATE_ENABLED=true                    # enable automatic image updates
AUTO_UPDATE_CRON_EXPRESSION=0 * * * *       # Cron schedule for update checks
AUTO_UPDATE_WARN_MINUTES=30                 # Minutes to warn players before auto-update/restart
AUTO_REBOOT_ENABLED=true                    # enable scheduled restarts
AUTO_REBOOT_EVEN_IF_PLAYERS_ONLINE=false    # reboot even if players connected
AUTO_REBOOT_WARN_MINUTES=5                  # Minutes to warn players before restart
AUTO_REBOOT_CRON_EXPRESSION=0 0 * * *       # Cron schedule for restarts
AUTO_PAUSE_ENABLED=true                     # auto-pause server when idle (no players)
AUTO_PAUSE_TIMEOUT_EST=180                  # Seconds of inactivity before auto-pause triggers
AUTO_PAUSE_LOG=true                         # log auto-pause/resume events
AUTO_PAUSE_DEBUG=false                      # enable debug logging for auto-pause
ENABLE_PLAYER_LOGGING=true                  # enable logging of player connections/actions
PLAYER_LOGGING_POLL_PERIOD=5                # Seconds between polling for new player log entries

# --- Server manager options (auto-update / restart / backup) ------------------
# These settings are used by the Docker wrapper to manage the server process.
# They are not in-game settings. See the docs linked at the top of this file.

# --- Game / world settings -----------------------------------------------------
# The following settings control Palworld gameplay (difficulty, PvP, rates, etc).

DIFFICULTY=Normal                                               # (None,Normal,Difficult) game difficulty
RANDOMIZER_TYPE=                                                # Randomizer type (empty disables; see docs)
RANDOMIZER_SEED=none                                            # Seed for the randomizer; 'none' uses default randomness
DAYTIME_SPEEDRATE=1.000000                                      # Day speed multiplier (1.0 normal, <1 slower, >1 faster)
NIGHTTIME_SPEEDRATE=1.000000                                    # Night speed multiplier
EXP_RATE=2.000000                                               # Experience gain multiplier (1.0 normal)
PAL_CAPTURE_RATE=1.000000                                       # Pal capture success multiplier
PAL_SPAWN_NUM_RATE=1.400000                                     # Pal spawn count multiplier
PAL_DAMAGE_RATE_ATTACK=1.000000                                 # Pal attack damage multiplier
PAL_DAMAGE_RATE_DEFENSE=1.000000                                # Pal defense multiplier
PLAYER_DAMAGE_RATE_ATTACK=1.000000                              # Player attack damage multiplier
PLAYER_DAMAGE_RATE_DEFENSE=1.000000                             # Player defense multiplier
PLAYER_STOMACH_DECREASE_RATE=1.000000                           # How fast player hunger drains (1.0 normal)
PLAYER_STAMINA_DECREASE_RATE=0.500000                           # Stamina drain speed (0.5 slower, 2.0 faster)
PLAYER_AUTO_HP_REGEN_RATE=1.000000                              # HP regen rate when not sleeping
PLAYER_AUTO_HP_REGEN_RATE_IN_SLEEP=1.500000                     # HP regen rate while sleeping
PAL_STOMACH_DECREASE_RATE=1.000000                              # Pal hunger drain rate
PAL_STAMINA_DECREASE_RATE=0.500000                              # Pal stamina drain rate
PAL_AUTO_HP_REGEN_RATE=1.000000                                 # Pal HP regen rate
PAL_AUTO_HP_REGEN_RATE_IN_SLEEP=5.000000                        # Pal HP regen rate while sleeping
BUILD_OBJECT_HP_RATE=1.000000                                   # Build health multiplier
BUILD_OBJECT_DAMAGE_RATE=1.000000                               # Damage taken by buildings multiplier
BUILD_OBJECT_DETERIORATION_DAMAGE_RATE=1.000000                 # Building deterioration rate multiplier
COLLECTION_DROP_RATE=2.000000                                   # Resource drop multiplier
COLLECTION_OBJECT_HP_RATE=1.000000                              # Resource node HP multiplier
COLLECTION_OBJECT_RESPAWN_SPEED_RATE=1.000000                   # Resource respawn speed multiplier
ENEMY_DROP_ITEM_RATE=2.000000                                   # Enemy drop rate multiplier
DEATH_PENALTY=None                                              # (None,Minor,Major, etc) penalty applied when a player dies
ENABLE_INVADER_ENEMY=True                                       # enable invader enemies (NPC attackers)
ACTIVE_UNKO=False                                               # enable UNKO mode (hardcore survival variant)
ENABLE_AIM_ASSIST_PAD=True                                      # enable aim assist on controller
ENABLE_AIM_ASSIST_KEYBOARD=False                                # enable aim assist on keyboard/mouse
DROP_ITEM_MAX_NUM=3000                                          # Max number of dropped items allowed in the world
DROP_ITEM_MAX_NUM_UNKO=100                                      # Max dropped items when UNKO mode is active
BASE_CAMP_MAX_NUM=128                                           # Max number of base camps per player
BASE_CAMP_WORKER_MAX_NUM=20                                     # Max workers per base camp
DROP_ITEM_ALIVE_MAX_HOURS=1.000000                              # Hours before dropped items despawn
AUTO_RESET_GUILD_NO_ONLINE_PLAYERS=False                        # reset guild after players are gone
AUTO_RESET_GUILD_TIME_NO_ONLINE_PLAYERS=72.00000                # Hours before guild auto-reset when empty
GUILD_PLAYER_MAX_NUM=20                                         # Max players in a guild
BASE_CAMP_MAX_NUM_IN_GUILD=4                                    # Max base camps per guild
PAL_EGG_DEFAULT_HATCHING_TIME=0.00000                           # Hours required for a Pal egg to hatch
WORK_SPEED_RATE=1.000000                                        # Work speed multiplier (crafting, gathering)
AUTO_SAVE_SPAN=30.000000                                        # Minutes between automatic save files
HARDCORE=False                                                  # enable hardcore mode (perma-death)
PAL_LOST=False                                                  # lose your pals on death (hardcore-like)
CAN_PICKUP_OTHER_GUILD_DEATH_PENALTY_DROP=False                 # allow picking up items from other guild death drops
ENABLE_NON_LOGIN_PENALTY=True                                   # apply penalties when players don't log in
ENABLE_FAST_TRAVEL=True                                         # enable fast travel
IS_START_LOCATION_SELECT_BY_MAP=True                            # allow selecting spawn location on map
EXIST_PLAYER_AFTER_LOGOUT=False                                 # keep player character in world after logout
INVISIBLE_OTHER_GUILD_BASE_CAMP_AREA_FX=False                   # hide other guild base markers
BUILD_AREA_LIMIT=False                                          # enable base building area limits
ITEM_WEIGHT_RATE=1.000000                                       # Multiplier for item weight (affects carry capacity)
COOP_PLAYER_MAX_NUM=6                                           # Max number of players in cooperative mode
REGION=                                                         # Region code (e.g., "US", "EU"), empty for auto
USEAUTH=True                                                    # require auth for players (steam/xbox/ps)
BAN_LIST_URL=https://api.palworldgame.com/api/banlist.txt       # URL of banlist service
REST_API_ENABLED=True                                           # enable REST API (port defined below)
REST_API_PORT=8212                                              # Port for REST API (TCP)
SHOW_PLAYER_LIST=True                                           # show player list in server browser
ENABLE_PREDATOR_BOSS_PAL=True                                   # enable predator boss pal spawns
MAX_BUILDING_LIMIT_NUM=0                                        # 0=unlimited, >0 to cap structures
SERVER_REPLICATE_PAWN_CULL_DISTANCE=15000.000000                # Distance to replicate actors to clients
SERVER_REPLICATE_PAWN_CULL_DISTANCE_IN_BASE_CAMP=5000.000000    # Distance within base camp
CROSSPLAY_PLATFORMS=(Steam,Xbox,PS5,Mac)                        # Platforms allowed to connect
USE_BACKUP_SAVE_DATA=True                                       # load save from backup if corruption detected
USE_DEPOT_DOWNLOADER=False                                      # use steam depot downloader for updates
INSTALL_BETA_INSIDER=False                                      # install beta insider build if available
ALLOW_GLOBAL_PALBOX_EXPORT=True                                 # allow exporting palboxes globally
ALLOW_GLOBAL_PALBOX_IMPORT=False                                # allow importing palboxes globally
EQUIPMENT_DURABILITY_DAMAGE_RATE=1.000000                       # Multiplier for equipment durability loss
ITEM_CONTAINER_FORCE_MARK_DIRTY_INTERVAL=1.000000               # Interval (seconds) to force container data save

# --- Multiplayer / PvP settings ------------------------------------------------
# These flags control how players interact and how the world behaves in multiplayer.

IS_MULTIPLAY=True                           # allow multiple players to connect
IS_PVP=False                                # enable player vs player combat
ENABLE_PLAYER_TO_PLAYER_DAMAGE=False        # allow players to damage each other
ENABLE_FRIENDLY_FIRE=False                  # allow friendly fire
ENABLE_DEFENSE_OTHER_GUILD_PLAYER=False     # Pals defend base from other guild players

# Box64 Configs (Only relevant for ARM64 hosts)
# These can be adjusted if the server keeps on crashing.
BOX64_DYNAREC_STRONGMEM=1   # This can be set to 2 or 3 with 3 being the most stable but worst performance.
BOX64_DYNAREC_BIGBLOCK=1    # This can be set to 0 for better stability but worse performance.
BOX64_DYNAREC_SAFEFLAGS=1   # This can be set to 2 for better stability but worse performance.
BOX64_DYNAREC_FASTROUND=1   # This can be set to 0 for better stability but worse performance.
BOX64_DYNAREC_FASTNAN=1     # This can be set to 0 for better stability but worse performance.
BOX64_DYNAREC_X87DOUBLE=0   # This can be set to 1 for better stability but worse performance.